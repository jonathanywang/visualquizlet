{
  "manifest_version": 3,
  "name": "VisualQuizlet",
  "version": "1.0.0",
  "description": "Practice drawing Chinese characters from Quizlet flashcards with stroke-by-stroke validation",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://cdn.jsdelivr.net/*"
  ],
  "action": {
    "default_title": "Open VisualQuizlet",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.quizlet.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
